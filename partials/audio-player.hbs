{{!-- Pill-shaped audio player shell. Hydrated by assets/js/player.js.
      Inputs:
        src           — audio URL (optional; JS falls back to first <audio> in post body)
        compact       — true for the smaller card variant
        download_name — filename hint for the download link --}}
<div class="pod-player {{#if compact}}pod-player--compact{{/if}}" data-pod-player {{#if src}}data-src="{{src}}"{{/if}}>

    {{#unless compact}}
    <button class="pod-player__skip" data-pod-skip="-30" type="button" aria-label="Skip back 30 seconds">−30</button>
    {{/unless}}

    <button class="pod-player__button" data-pod-toggle type="button" aria-label="Play" data-playing="false">
        <svg data-icon-play class="pod-player__icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M8 5v14l11-7z"/>
        </svg>
        <svg data-icon-pause class="pod-player__icon" viewBox="0 0 24 24" aria-hidden="true" style="display:none;">
            <rect x="6" y="5" width="4" height="14"/>
            <rect x="14" y="5" width="4" height="14"/>
        </svg>
    </button>

    {{#unless compact}}
    <button class="pod-player__skip" data-pod-skip="30" type="button" aria-label="Skip forward 30 seconds">+30</button>
    {{/unless}}

    <div class="pod-player__waveform" data-pod-scrub role="slider" aria-label="Seek" tabindex="0" aria-valuemin="0" aria-valuemax="0" aria-valuenow="0"></div>

    <div class="pod-player__time">
        <span class="pod-player__time-current" data-pod-current>0:00</span>
        <span class="pod-player__time-total" data-pod-total>0:00</span>
    </div>

    {{#unless compact}}
    <button class="pod-player__speed" data-pod-speed type="button" aria-label="Playback speed">1×</button>
    <a class="pod-player__download" data-pod-download href="{{src}}" download="{{download_name}}" aria-label="Download audio">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <path d="M12 4v12m0 0l-5-5m5 5l5-5M4 20h16"/>
        </svg>
    </a>
    {{/unless}}
</div>
