<section id="subscribe" class="surface-inverse py-8 sm:py-10 px-6 sm:px-10 lg:px-20">
    <div class="mx-auto flex max-w-content flex-col items-start gap-8 lg:flex-row lg:items-center lg:justify-between">
        <div class="flex flex-col gap-1">
            <span class="font-mono text-[11px] uppercase" style="letter-spacing: 0.12em; color: var(--color-accent-500);">{{t "Listen on"}}</span>
            <h2 class="font-sans text-[22px] font-semibold tracking-snug" style="color: var(--color-inverse-text); margin: 0;">{{t "Your podcast app, your call."}}</h2>
        </div>

        <div class="subscribe-band__pills flex flex-wrap items-center gap-2 sm:gap-3">
            {{> subscribe-pills surface="dark"}}
        </div>
    </div>
</section>
