{{!< default}}

<section class="px-6 sm:px-10 lg:px-20 pt-20 pb-12">
    <div class="mx-auto max-w-content">
        {{#tag}}
        <div class="eyebrow"><span class="eyebrow-text">{{plural pagination.total empty="ARCHIVE" singular="ARCHIVE · % EPISODE" plural="ARCHIVE · % EPISODES"}}</span></div>
        <h1 class="mt-3 font-sans text-[44px] sm:text-[68px] font-bold tracking-display leading-[1] m-0" style="color: var(--color-text);">{{name}}</h1>
        {{#if description}}
            <p class="mt-5 font-serif text-[18px] sm:text-[20px] leading-[150%] max-w-[800px] m-0" style="color: var(--color-text-body);">{{description}}</p>
        {{/if}}
        {{/tag}}
    </div>
</section>

<section class="px-6 sm:px-10 lg:px-20 pb-20 sm:pb-28">
    <div class="mx-auto max-w-content">
        {{#if posts}}
            <div class="post-feed">
                {{#foreach posts}}
                    {{> post-card}}
                {{/foreach}}
            </div>

            {{#if pagination.next}}
                <div class="flex justify-center mt-14">
                    <a href="{{page_url pagination.next}}" class="pill" style="border-color: var(--color-text);">
                        {{t "Load more"}} <span class="pill__arrow" style="color: var(--color-accent);">→</span>
                    </a>
                </div>
            {{/if}}
        {{else}}
            <p class="text-center font-serif text-lg py-12" style="color: var(--color-text-muted);">{{t "No episodes yet under this tag."}}</p>
        {{/if}}
    </div>
</section>
